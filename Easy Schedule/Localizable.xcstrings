    "events_guide_intro" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Events you create, events created for you, and events you create for others appear here.\n\nTap an event to chat and manage todos.\n\nUse the top-right button to customize events and chat.\n\nYour busy hours and off days are always synced, so others only see available time and never double-book.\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたが作成したイベント、あなたのために作成されたイベント、そして他の人のために作成したイベントがここに表示されます。\n\nイベントをタップして、チャットやToDoを管理できます。\n\n右上のボタンから、イベントやチャットをカスタマイズできます。\n\nあなたの忙しい時間や休暇日は常に同期され、他の人は空いている時間だけを見るため、予定が重複することはありません。\n"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내가 만든 이벤트, 나를 위해 생성된 이벤트, 그리고 다른 사람을 위해 만든 이벤트가 여기에 표시됩니다.\n\n이벤트를 탭하여 채팅하고 할 일을 관리할 수 있습니다.\n\n오른쪽 상단 버튼을 사용해 이벤트와 채팅을 사용자화할 수 있습니다.\n\n내 바쁜 시간과 휴무일은 항상 동기화되어, 다른 사람이 가능한 시간만 보고 중복 예약을 방지할 수 있습니다.\n"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các sự kiện bạn tạo, sự kiện được tạo cho bạn và sự kiện bạn tạo cho người khác sẽ hiển thị tại đây.\n\nChạm vào một sự kiện để trò chuyện và quản lý công việc cần làm.\n\nSử dụng nút ở góc trên bên phải để tùy chỉnh sự kiện và trò chuyện.\n\nGiờ bận và ngày nghỉ của bạn luôn được đồng bộ, giúp người khác chỉ thấy thời gian trống và tránh trùng lịch.\n"
          }
        }
      }
    },
    "events_help_chat_desc" : {
      "comment" : "Description of the \"Chat\" feature in the events help sheet.",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chat inside each event to exchange quick messages, keep both sides updated in real time. Messages sync instantly, and old chats are automatically removed after the event ends.\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各イベント内でチャットを使って素早くメッセージをやり取りし、双方の最新状況をリアルタイムで共有できます。メッセージは即時に同期され、イベント終了後は古いチャットが自動的に削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 이벤트에는 채팅 기능이 있어 빠르게 메시지를 주고받고 실시간으로 서로의 상태를 확인할 수 있습니다. 메시지는 즉시 동기화되며, 이벤트가 종료되면 이전 채팅은 자동으로 삭제됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Trò chuyện ngay trong từng sự kiện để trao đổi nhanh, cập nhật theo thời gian thực. Tin nhắn được đồng bộ tức thì, tự xoá khi sự kiện kết thúc.\n"
          }
        }
      }
    },
    "events_help_chat_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chat in events"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
