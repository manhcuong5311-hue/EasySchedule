    "events_help_chat_desc" : {
      "comment" : "Description of the \"Chat\" feature in the events help sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chat inside each event to exchange quick messages, keep both sides updated in real time. Messages sync instantly, and old chats are automatically removed after the event ends.\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各イベント内でチャットを使って素早くメッセージをやり取りし、双方の最新状況をリアルタイムで共有できます。メッセージは即時に同期され、イベント終了後は古いチャットが自動的に削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 이벤트에는 채팅 기능이 있어 빠르게 메시지를 주고받고 실시간으로 서로의 상태를 확인할 수 있습니다. 메시지는 즉시 동기화되며, 이벤트가 종료되면 이전 채팅은 자동으로 삭제됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Trò chuyện ngay trong từng sự kiện để trao đổi nhanh, cập nhật theo thời gian thực. Tin nhắn được đồng bộ tức thì, tự xoá khi sự kiện kết thúc.\n"
          }
        }
      }
    },
    "events_help_chat_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👁‍🗨 Chat in events"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👁‍🗨 イベント内チャット"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👁‍🗨 이벤트 채팅"
          }
        },
