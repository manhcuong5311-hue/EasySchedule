          }
        }
      }
    },
    "help_section_created_for_others_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Events you created on someone else’s calendar will appear here. These events are also synced with both their calendar and your current calendar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのイベントは、相手のカレンダーと自分のカレンダーの両方に同期されます。\n"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 사람의 캘린더에 생성한 이벤트가 여기에 표시됩니다. 이 이벤트는 상대방의 캘린더와 내 현재 캘린더에 모두 동기화됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các sự kiện bạn tạo trên lịch của người khác sẽ hiển thị tại đây. \nNhững sự kiện này được đồng bộ với cả lịch của họ và lịch hiện tại của bạn.\n"
          }
        }
      }
    },
