    "help_section_access_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View and manage who can see your calendar. You can only add events for users who granted you permission, otherwise you cannot modify their appointments and vice versa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのカレンダーを閲覧できるユーザーを確認・管理できます。アクセスを許可したユーザーに対してのみイベントを追加できます。許可がない場合、相手の予定を編集できず、相手もあなたの予定を編集できません。"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Xem ai đang được phép xem lịch của bạn và quản lý quyền truy cập. Bạn chỉ có thể thêm lịch cho người đã đồng ý cho bạn tạo lịch, nếu không bạn sẽ không thể chỉnh sửa thêm lịch hẹn với họ và ngược lại."
          }
        }
      }
    },
    "help_section_access_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👥 Access Permissions"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👥 アクセス権限"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "👥 Quyền truy cập"
          }
        }
      }
    },
    "help_section_add_event_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After loading a partner calendar, tap the plus button at the top right to create an event. Busy times are shown in light red. Events created on their calendar will also be added automatically to your own calendar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーカレンダーを読み込んだ後、右上のプラスボタンをタップしてイベントを作成します。予定ありの時間は薄赤色で表示されます。相手のカレンダーで作成したイベントは、自分のカレンダーにも自動的に追加されます。"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sau khi load lịch, bạn có thể nhấn nút dấu + ở góc phải để đặt lịch trên lịch của người đó. Trong lịch đối tác bạn sẽ thấy khung giờ bận được đánh dấu bằng màu đỏ nhạt. Khi bạn đặt lịch trên lịch đối tác, lịch được thêm cũng sẽ tự động được thêm vào lịch của bạn."
          }
        }
      }
    },
    "help_section_add_event_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📅 Book an event on partner’s calendar"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📅 パートナーカレンダーでイベントを予約"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "📅 Đặt lịch trên lịch đối tác"
          }
        }
      }
    },
    "help_section_created_for_others_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Events you created on someone else’s calendar will appear here. These events are also synced with both their calendar and your current calendar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "他のユーザーのカレンダー上で作成したイベントがここに表示されます。これらのイベントは、相手のカレンダーと自分の現在のカレンダーの両方に同期されます。"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Các sự kiện mà bạn tạo trên lịch của người khác sẽ hiện ở đây. Lịch bạn thêm cho người khác cũng sẽ được đồng bộ trong mục Lịch hiện tại của bạn và họ."
          }
        }
      }
    },
