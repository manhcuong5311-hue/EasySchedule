      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Someone sends you their shared calendar link. Paste the link or UID into the input field above, then tap Load Calendar to view their schedule."
          }
        },
        "ja" : {
