    "events_help_weekgroup_desc" : {
      "comment" : "Description of how to view and interact with the list of events grouped by week.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Past events are grouped by week. Tap on any week to see all events for that week in detail."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "過去のイベントは週ごとにグループ化されています。任意の週をタップすると、その週のすべてのイベントを詳細に確認できます。"
