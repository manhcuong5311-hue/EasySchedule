          }
        }
      }
    },
    "my_calendar_help_section_share_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can share your calendar link with others so they can view your availability and book appointments with you."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カレンダーのリンクを共有すると、相手はあなたの空き状況を確認し、予定を予約できるようになります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캘린더 링크를 다른 사람과 공유하여 가능한 시간을 확인하고 약속을 예약하도록 할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có thể chia sẻ link lịch cho người khác để họ xem lịch rảnh/bận của bạn và đặt lịch với bạn."
          }
        }
      }
    },
    "my_calendar_help_section_share_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Share Your Calendar"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "予定を予約してもらう"
          }
        },
        "ko" : {
          "stringUnit" : {
