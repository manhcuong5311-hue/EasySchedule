    "onboarding_desc_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The easiest way for two people to stay in sync without endless back-and-forth messages."
          }
        },
        "ja" : {
          "stringUnit" : {
