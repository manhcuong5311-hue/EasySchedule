    "events_help_delete_desc" : {
      "comment" : "A description of how to delete an event.",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Swipe left on an event to delete it. You will be asked to confirm before the event is removed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "イベントを左にスワイプすると削除できます。削除前に確認が求められます。"
          }
        },
        "ko" : {
