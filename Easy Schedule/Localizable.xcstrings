    },
    "my_calendar_help_section_todo_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each event includes a chat where participants can add todos or notes related to that event. Todos help everyone stay aligned on what needs to be done."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "各イベントにはチャットがあり、参加者はそのイベントに関連するToDoやメモを追加できます。ToDoを使うことで、必要な作業を共有し、把握しやすくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "각 이벤트에는 채팅이 포함되어 있어 참여자가 할 일이나 메모를 추가할 수 있습니다. 할 일 목록을 통해 필요한 작업을 모두가 쉽게 공유하고 확인할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mỗi sự kiện có một khung chat cho phép các bên tham gia thêm todo hoặc ghi chú liên quan đến sự kiện đó. Todo giúp mọi người theo dõi và thống nhất các việc cần làm."
          }
        }
      }
    },
    "my_calendar_help_section_todo_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
