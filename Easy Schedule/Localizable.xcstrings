    "onboarding_desc_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The easiest way for two people to stay in sync without endless back-and-forth messages."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "やり取りを繰り返すことなく、2人の予定を簡単に同期できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "끝없는 메시지 없이 두 사람의 일정을 쉽게 맞출 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giữ cho 2 người luôn đồng bộ mà không cần phải chuyển qua giữa nhiều ứng dụng."
          }
        }
      }
    },
    "onboarding_desc_2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "See each other’s schedules and find the right time without conflicts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お互いの予定を確認し、無駄な調整なく最適な時間を見つけられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "서로의 일정을 한눈에 보고 충돌 없이 적절한 시간을 찾으세요."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xem lịch của nhau và dễ dàng tìm thời gian phù hợp mà không bị trùng lịch.\n"
          }
        }
      }
    },
    "onboarding_desc_3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discuss details right where the event happens — no separate chat apps needed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "予定ごとにそのまま会話。別のチャットアプリは不要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이벤트가 있는 바로 그곳에서 대화하세요. 별도의 채팅 앱이 필요 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bàn luận chi tiết ngay cuộc hẹn - không cần những ứng dụng khác."
          }
        }
      }
    },
    "onboarding_desc_4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Create and track to-dos linked to shared events, so nothing gets missed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有予定に紐づくタスクを管理し、抜け漏れを防ぎます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
