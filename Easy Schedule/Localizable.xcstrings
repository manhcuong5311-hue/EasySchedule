    "privacy_policy" : {
      "comment" : "Chính sách quyền riêng tư",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Privacy Policy"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chính sách quyền riêng tư"
          }
        }
      }
    },
    "privacy_text" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EasySchedule respects your privacy. All calendar events created in the app are stored locally on your device and are not shared with third parties.\nYou may choose to share events via links, but this only occurs when you explicitly decide to do so.\nThe app does not track you, does not collect location, contacts, or health data.\nPremium subscription information is securely processed through Apple’s In-App Purchase system.\nWe may collect crash or anonymous usage data to improve app performance, but this data is not linked to you.\nIf you have any privacy questions, please contact: Manhcuong5311@gmail.com.\n\nVersion: 1.0.4\nDeveloper: SamCorp.EasySchedule\n"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "EasySchedule tôn trọng quyền riêng tư của bạn. Tất cả các sự kiện lịch được tạo trong ứng dụng được lưu trữ cục bộ trên thiết bị và không chia sẻ với bên thứ ba.\nBạn có thể chọn chia sẻ sự kiện thông qua liên kết, nhưng điều này chỉ được thực hiện khi bạn chủ động.\nỨng dụng không theo dõi bạn, không thu thập thông tin vị trí, danh bạ, hay dữ liệu sức khỏe.\nThông tin đăng ký Premium được xử lý an toàn qua hệ thống In-App Purchase của Apple.\nChúng tôi có thể thu thập dữ liệu crash hoặc sử dụng ẩn danh để cải thiện hiệu năng ứng dụng, nhưng dữ liệu này không liên kết với bạn.\nNếu có câu hỏi về quyền riêng tư, vui lòng liên hệ: Manhcuong5311@gmail.com.\n\nPhiên bản: 1.0.4\nNhà phát triển: SamCorp.Easyschedule\n"
          }
        }
      }
    },
