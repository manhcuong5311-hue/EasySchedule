    "faq_4_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Free accounts can create 4 events per day, and 7 days from today."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "無料アカウントでは、1日2件まで、今日から7日先までイベントを作成できます。\n"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "무료 계정은 하루에 최대 2개의 이벤트를 생성할 수 있으며, 오늘 기준 7일 이내까지만 가능합니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Người dùng miễn phí được tạo 2 lịch mỗi ngày, và 7 ngày tới tính từ hiện tại."
          }
        }
      }
    },
    "faq_4_q" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How many events can free users create?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無料ユーザーは何件イベントを作成できますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "무료 사용자는 이벤트를 몇 개까지 만들 수 있나요?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tài khoản miễn phí được tạo bao nhiêu lịch?"
          }
        }
      }
    },
    "faq_5_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium\nLets you create up to 20 events per day\nand schedule appointments up to 90 days in advance.\n\nEnjoy extended messaging,\nmanage up to 20 tasks per event,\nand keep your data synced across devices.\n\nPro\nDesigned for power users.\n\nCreate up to 50 events per day\nand schedule appointments up to 270 days in advance.\n\nEnjoy unlimited messaging,\nadvanced scheduling,\nand higher task limits.\n"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレミアム\n1日に最大20件のイベントを作成でき、\n最大90日先まで予定を登録できます。\n\n拡張メッセージ機能を利用でき、\nイベントごとに最大20件のタスクを管理でき、\nデバイス間でデータを同期できます。\n\nプロ\nパワーユーザー向けプランです。\n\n1日に最大50件のイベントを作成でき、\n最大270日先まで予定を登録できます。\n\nメッセージ無制限、\n高度なスケジューリング、\nより多いタスク上限を利用できます。\n"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "프리미엄\n하루 최대 20개의 이벤트를 생성하고\n최대 90일 전까지 일정을 예약할 수 있습니다.\n\n확장된 메시징 기능을 사용하고,\n이벤트당 최대 20개의 작업을 관리하며,\n기기 간 데이터 동기화를 지원합니다.\n\n프로\n고급 사용자를 위한 요금제입니다.\n\n하루 최대 50개의 이벤트를 생성하고\n최대 270일 전까지 일정을 예약할 수 있습니다.\n\n무제한 메시징,\n고급 일정 관리,\n더 높은 작업 제한을 제공합니다.\n"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium\nCho phép bạn tạo tối đa 20 sự kiện mỗi ngày\nvà lên lịch trước tối đa 90 ngày.\n\nTrải nghiệm nhắn tin mở rộng,\nquản lý tối đa 20 công việc cho mỗi sự kiện,\nvà đồng bộ dữ liệu trên nhiều thiết bị.\n\nPro\nDành cho người dùng nâng cao.\n\nTạo tối đa 50 sự kiện mỗi ngày\nvà lên lịch trước tối đa 270 ngày.\n\nTrải nghiệm nhắn tin không giới hạn,\nlập lịch nâng cao,\nvà giới hạn công việc cao hơn.\n"
          }
        }
      }
    },
    "faq_5_q" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What are the benefits of Premium and pro ?"
          }
        },
        "ja" : {
