        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지난 이벤트 모드에서는 검색창을 사용해 제목이나 내용으로 이벤트를 검색할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ở chế độ lịch đã qua, bạn có thể tìm sự kiện theo tiêu đề hoặc nội dung bằng thanh tìm kiếm."
          }
        }
      }
    },
