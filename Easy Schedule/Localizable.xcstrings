    "events_help_segment_desc" : {
      "comment" : "The text under the \"Segment\" heading in the events help sheet.",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can switch between current events and past events. Current events show all upcoming schedules (including events you created, events you created for others, and events others created for you). Past events display older events grouped by week."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のイベントと過去のイベントを切り替えることができます。現在のイベントには、今後の予定（自分が作成したイベント、他者のために作成したイベント、他者が自分のために作成したイベント）が表示されます。過去のイベントは週ごとにまとめて表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 이벤트와 지난 이벤트 사이를 전환할 수 있습니다. 현재 이벤트에는 내가 만든 이벤트, 다른 사람을 위해 만든 이벤트, 그리고 다른 사람이 나를 위해 만든 이벤트를 포함한 모든 예정 일정이 표시됩니다. 지난 이벤트는 주 단위로 묶어 표시됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có thể xem lịch hiện tại hoặc lịch đã qua. Chế độ lịch hiện tại hiển thị các sự kiện sắp tới( Bao gồm lịch của bạn tạo, lịch bạn tạo cho người khác và lịch người khác tạo cho bạn), còn lịch đã qua hiển thị các sự kiện cũ và nhóm theo từng tuần."
          }
        }
      }
    },
