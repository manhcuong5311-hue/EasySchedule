    "faq_busy_hours_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busy hours let you mark time periods when you are unavailable. These times help prevent scheduling conflicts even if no events exist. Busy hours are different from days off and can be edited anytime."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "対応不可の時間を設定すると、予定がなくてもその時間帯は予約や予定の作成を避けることができます。休日とは異なり、いつでも編集できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "바쁜 시간을 설정하면 일정이 없어도 해당 시간대에는 새로운 일정을 피할 수 있습니다. 휴일과는 다르며 언제든지 수정할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Giờ bận cho phép bạn đánh dấu các khoảng thời gian bạn không rảnh. Những khoảng này sẽ được dùng để tránh đặt lịch trùng, ngay cả khi không có sự kiện nào. Giờ bận khác với ngày nghỉ và có thể chỉnh sửa bất cứ lúc nào."
          }
        }
      }
    },
