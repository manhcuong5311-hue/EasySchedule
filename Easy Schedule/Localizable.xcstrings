    "help_section_access_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View and manage who can see your calendar. You can only add events for users who granted you permission, otherwise you cannot modify their appointments and vice versa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたのカレンダーを閲覧できるユーザーを確認・管理できます。アクセスを許可したユーザーに対してのみイベントを追加できます。許可がない場合、相手の予定を編集できず、相手もあなたの予定を編集できません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캘린더를 볼 수 있는 사용자를 확인하고 관리할 수 있습니다. 권한을 부여한 사용자에게만 이벤트를 추가할 수 있으며, 그렇지 않으면 서로의 일정을 수정할 수 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Xem ai đang được phép xem lịch của bạn và quản lý quyền truy cập. Bạn chỉ có thể thêm lịch cho người đã đồng ý cho bạn tạo lịch, nếu không bạn sẽ không thể chỉnh sửa thêm lịch hẹn với họ và ngược lại."
          }
        }
      }
    },
    "help_section_access_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Access Permissions"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "アクセス権限"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "접근 권한"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Quyền truy cập"
          }
        }
      }
    },
    "help_section_add_event_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After loading a partner calendar, tap the plus button at the top right to create an event. Busy times are shown in light red. Events created on their calendar will also be added automatically to your own calendar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーカレンダーを読み込んだ後、右上のプラスボタンをタップしてイベントを作成します。予定ありの時間は薄赤色で表示されます。相手のカレンダーで作成したイベントは、自分のカレンダーにも自動的に追加されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파트너 캘린더를 불러온 후 오른쪽 상단의 ‘＋’ 버튼을 탭하여 이벤트를 생성하세요. 바쁜 시간은 연한 빨간색으로 표시되며, 상대 캘린더에 생성한 이벤트는 내 캘린더에도 자동으로 추가됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sau khi tải lịch đối tác, bạn có thể nhấn nút + ở góc trên bên phải để tạo sự kiện. \nCác khung giờ bận sẽ được hiển thị bằng màu đỏ nhạt. \nSự kiện tạo trên lịch đối tác sẽ tự động được đồng bộ vào lịch của bạn.\n"
          }
        }
      }
    },
    "help_section_add_event_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Book an event on partner’s calendar"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーカレンダーでイベントを予約"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
