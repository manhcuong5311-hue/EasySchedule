    "faq_chat_limit_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Free users can send up to 10 chat messages per event. After reaching the limit, you can upgrade to Premium to continue chatting without limits, or wait until the other participant opens the chat."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "無料ユーザーは、イベントごとに最大10件までメッセージを送信できます。上限に達した場合は、Premiumにアップグレードして無制限でチャットするか、相手がチャットを開くまでお待ちください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "무료 사용자는 이벤트당 최대 10개의 메시지를 보낼 수 있습니다. 제한에 도달하면 Premium으로 업그레이드하여 무제한으로 채팅하거나, 상대방이 채팅을 열 때까지 기다릴 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Người dùng miễn phí có thể gửi tối đa 10 tin nhắn cho mỗi sự kiện. Khi đạt giới hạn, bạn có thể nâng cấp lên Premium để tiếp tục chat không giới hạn, hoặc chờ khi người còn lại mở cuộc trò chuyện."
          }
        }
      }
