    "my_calendar_help_section_calendar_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Here you can view all of your appointments (including events you created, events created for you by others, and events you created for other people). All events are displayed by day."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここでは、自分のすべての予定（自分が作成したイベント、他の人があなたのために作成したイベント、あなたが他の人のために作成したイベント）を確認できます。すべてのイベントは日別で表示されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에서 내가 만든 이벤트, 다른 사람이 나를 위해 만든 이벤트, 그리고 내가 다른 사람을 위해 만든 이벤트를 포함한 모든 약속을 확인할 수 있습니다. 모든 이벤트는 날짜별로 표시됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tại đây bạn có thể xem toàn bộ lịch hẹn của mình (bao gồm lịch bạn tạo, lịch người khác tạo cho bạn và lịch bạn tạo cho người khác). \nCác sự kiện được hiển thị theo ngày.\n"
          }
        }
      }
    },
    "my_calendar_help_section_calendar_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your Calendar"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " あなたのカレンダー"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내 캘린더"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lịch của bạn"
          }
        }
      }
    },
    "my_calendar_help_section_conflict_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When this option is turned off, you can only create events that overlap by a maximum of 5 minutes. Conflicting events cannot have the same start and end time and cannot share the same title. Overlaps are only allowed within a limited range."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このオプションをオフにすると、重複できるのは最大5分までとなります。競合するイベントは、開始時刻と終了時刻が同一だったり、同じタイトルを共有したりすることはできません。重複は限られた範囲内のみ許可されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 옵션을 끄면 최대 5분까지만 일정이 겹치도록 이벤트를 생성할 수 있습니다. 충돌하는 이벤트는 시작 및 종료 시간이 같을 수 없으며, 동일한 제목을 사용할 수 없습니다. 겹침은 제한된 범위 내에서만 허용됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu không bật bạn chỉ có thể thêm lịch trùng nhau tối đa 5 phút, Lịch trùng không được phép cùng thời gian bắt đầu và kết thúc, không được cùng tiêu đề, chỉ được phép trùng vào nhau 1 khoảng thời gian nhất định."
          }
        }
      }
    },
    "my_calendar_help_section_conflict_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : " Allow Conflicting Events"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "イベントの競合を許可"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "일정 겹침 허용"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cho phép trùng lịch"
          }
        }
      }
    },
    "my_calendar_help_section_offday_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select a date and tap the button to mark it as a day off or to reopen it as a working day. Your day-off settings will be synced to the server. When others have permission to view or add events to your calendar, they will see your busy times as well as your day-off status to avoid scheduling conflicts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日付を選択し、ボタンをタップすると休暇日として設定したり、勤務日に戻したりできます。休暇日設定はサーバーに同期されます。他のユーザーにあなたのカレンダーへの閲覧・追加権限がある場合、予定あり時間と休暇日ステータスが表示され、スケジュールの重複を避けられます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "날짜를 선택한 후 버튼을 탭하여 휴무일로 설정하거나 근무일로 다시 변경할 수 있습니다. 휴무일 설정은 서버에 동기화되며, 캘린더를 볼 수 있거나 이벤트를 추가할 수 있는 다른 사용자는 바쁜 시간과 휴무일 상태를 확인하여 일정 충돌을 피할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn một ngày và bấm nút để đặt ngày nghỉ hoặc mở lại ngày làm việc. Ngày nghỉ sẽ được đồng bộ lên máy chủ và khi người khác được quyền xem và thêm lịch vào lịch của bạn, họ sẽ thấy khung giờ bận và cả ngày nghỉ của bạn để tránh đặt trùng khung giờ đã có lịch và ngày nghỉ của bạn."
          }
        }
      }
    },
    "my_calendar_help_section_offday_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Set Day Off"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "休暇日を設定"
          }
        },
        "ko" : {
          "stringUnit" : {
