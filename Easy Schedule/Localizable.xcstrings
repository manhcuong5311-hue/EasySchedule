    "help_section_add_event_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After loading a partner calendar, tap the plus button at the top right to create an event. Busy times are shown in light red. Events created on their calendar will also be added automatically to your own calendar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パートナーカレンダーを読み込んだ後、右上のプラスボタンをタップしてイベントを作成します。予定ありの時間は薄赤色で表示されます。相手のカレンダーで作成したイベントは、自分のカレンダーにも自動的に追加されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파트너 캘린더를 불러온 후 오른쪽 상단의 ‘＋’ 버튼을 탭하여 이벤트를 생성하세요. 바쁜 시간은 연한 빨간색으로 표시되며, 상대 캘린더에 생성한 이벤트는 내 캘린더에도 자동으로 추가됩니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sau khi load lịch, bạn có thể nhấn nút dấu + ở góc phải để đặt lịch trên lịch của người đó. Trong lịch đối tác bạn sẽ thấy khung giờ bận được đánh dấu bằng màu đỏ nhạt. Khi bạn đặt lịch trên lịch đối tác, lịch được thêm cũng sẽ tự động được thêm vào lịch của bạn."
          }
        }
      }
    },
