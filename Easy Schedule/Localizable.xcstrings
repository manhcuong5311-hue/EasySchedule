          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tạo và kiểm soát danh sách công việc ( to-dos) ngay trong sự kiện, không bỏ lỡ chi tiết quan trọng nào."
          }
        }
