    "faq_1_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open an event → tap Share Link. The recipient can view your free timeslot and busyslot, but cannot edit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "イベントを開き →「共有リンク」をタップします。受け取った相手は、あなたの空き時間と予定あり時間のみ閲覧できますが、編集はできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이벤트를 열고 ‘링크 공유’를 탭하세요. 상대방은 가능한 시간과 바쁜 시간을 볼 수 있지만, 수정은 할 수 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Trong lịch, chọn sự kiện → bấm Chia sẻ liên kết. Người nhận có thể xem khung giờ rảnh bận của bạn để đặt lịch nhưng không thể chỉnh sửa."
          }
        }
      }
    },
    "faq_1_q" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How do I share my schedule with someone?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スケジュールを他の人と共有するには？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일정을 다른 사람과 어떻게 공유하나요?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tôi chia sẻ lịch cho người khác bằng cách nào?"
          }
        }
      }
    },
    "faq_2_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "They must send you a Request Access. You can approve or decline. Do not approve some one you dont know to prevent spam…etc"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "相手が「アクセスリクエスト」を送る必要があります。あなたは承認または拒否できます。スパム防止のため、知らない人のリクエストは承認しないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "상대방이 접근 요청을 보내야 합니다. 요청을 승인하거나 거절할 수 있으며, 스팸을 방지하기 위해 모르는 사람의 요청은 승인하지 않는 것이 좋습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Họ cần gửi Request Access. Bạn sẽ nhận thông báo để chấp nhận hoặc từ chối. Tránh chấp nhận những người không biết."
          }
        }
      }
    },
    "faq_2_q" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How can others view my calendar?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "他の人はどのようにして私のカレンダーを閲覧できますか？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다른 사람은 어떻게 내 캘린더를 볼 수 있나요?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Người khác muốn xem lịch của tôi phải làm gì?"
          }
        }
      }
    },
    "faq_3_a" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No. People you approve can view your only free slot and busy slot, they can not see your event’s detail."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いいえ。承認した相手は、あなたの空き時間と予定あり時間のみ表示できます。イベントの詳細を見ることはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아니요. 승인한 사용자만 빈 시간과 바쁜 시간만 볼 수 있으며, 이벤트의 상세 내용은 볼 수 없습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Không. Chỉ những người bạn cấp quyền mới có thể xem khung giờ bận và rảnh, và có thể đặt lịch trên lịch  của bạn. Họ không có quyền xem thông tin lịch của bạn."
          }
        }
      }
    },
    "faq_3_q" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Is my calendar public?"
          }
        },
        "ja" : {
          "stringUnit" : {
