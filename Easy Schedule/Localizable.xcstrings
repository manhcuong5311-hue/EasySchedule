      }
    },
    "my_calendar_help_section_conflict_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When this option is turned off, you can only create events that overlap by a maximum of 5 minutes. Conflicting events cannot have the same start and end time and cannot share the same title. Overlaps are only allowed within a limited range."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このオプションをオフにすると、重複できるのは最大5分までとなります。競合するイベントは、開始時刻と終了時刻が同一だったり、同じタイトルを共有したりすることはできません。重複は限られた範囲内のみ許可されます。"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu không bật bạn chỉ có thể thêm lịch trùng nhau tối đa 5 phút, Lịch trùng không được phép cùng thời gian bắt đầu và kết thúc, không được cùng tiêu đề, chỉ được phép trùng vào nhau 1 khoảng thời gian nhất định."
          }
        }
      }
    },
    "my_calendar_help_section_conflict_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ Allow Conflicting Events"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️ イベントの競合を許可"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "⚠️ Cho phép trùng lịch"
          }
        }
      }
    },
    "my_calendar_help_section_offday_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select a date and tap the button to mark it as a day off or to reopen it as a working day. Your day-off settings will be synced to the server. When others have permission to view or add events to your calendar, they will see your busy times as well as your day-off status to avoid scheduling conflicts."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "日付を選択し、ボタンをタップすると休暇日として設定したり、勤務日に戻したりできます。休暇日設定はサーバーに同期されます。他のユーザーにあなたのカレンダーへの閲覧・追加権限がある場合、予定あり時間と休暇日ステータスが表示され、スケジュールの重複を避けられます。"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn một ngày và bấm nút để đặt ngày nghỉ hoặc mở lại ngày làm việc. Ngày nghỉ sẽ được đồng bộ lên máy chủ và khi người khác được quyền xem và thêm lịch vào lịch của bạn, họ sẽ thấy khung giờ bận và cả ngày nghỉ của bạn để tránh đặt trùng khung giờ đã có lịch và ngày nghỉ của bạn."
          }
        }
      }
    },
    "my_calendar_help_section_offday_title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌙 Set Day Off"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌙 休暇日を設定"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌙 Đặt ngày nghỉ"
          }
        }
      }
    },
    "my_calendar_help_section_share_desc" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can share your calendar link with others so they can view your availability and book appointments with you."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "カレンダーのリンクを共有すると、相手はあなたの空き状況を確認し、予定を予約できるようになります。"
          }
        },
        "vi" : {
