        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "웹사이트 🧾 개인정보 처리방침 및 앱 정보"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
